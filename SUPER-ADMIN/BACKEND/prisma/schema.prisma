  status                                                            String                  @default("active") @db.VarChar(50)
  created_at                                                        DateTime?               @default(now()) @db.Timestamp(6)
  updated_at                                                        DateTime?               @default(now()) @db.Timestamp(6)
  created_by                                                        String?                 @db.VarChar(100)
  school                                                            school                  @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  application                                                       application[]
  application_documents_application_documents_uploaded_byToapp_user application_documents[] @relation("application_documents_uploaded_byToapp_user")
  application_documents_application_documents_verified_byToapp_user application_documents[] @relation("application_documents_verified_byToapp_user")
