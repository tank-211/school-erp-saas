generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model academic_year {
  id            BigInt          @id @default(autoincrement())
  school_id     BigInt
  year_name     String          @db.VarChar(50)
  start_date    DateTime        @db.Date
  end_date      DateTime        @db.Date
  is_active     Boolean?        @default(false)
  status        String?         @default("inactive") @db.VarChar(50)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?       @default(now()) @db.Timestamp(6)
  created_by    String?         @db.VarChar(100)
  updated_by    String?         @db.VarChar(100)
  school        school          @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  admission     admission[]
  application   application[]
  fee_structure fee_structure[]
  lead          lead[]

  @@unique([school_id, year_name])
  @@index([is_active], map: "idx_academic_year_is_active")
  @@index([school_id], map: "idx_academic_year_school_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model admission {
  id                     BigInt                   @id @default(autoincrement())
  school_id              BigInt
  student_id             BigInt
  lead_id                BigInt?
  academic_year_id       BigInt
  class_id               BigInt
  section_id             BigInt
  admission_date         DateTime                 @db.Date
  status                 String?                  @default("active") @db.VarChar(50)
  admission_type         String?                  @db.VarChar(50)
  registration_number    String?                  @unique @db.VarChar(50)
  previous_school        String?                  @db.VarChar(255)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime?                @default(now()) @db.Timestamp(6)
  created_by             String?                  @db.VarChar(100)
  application_id         BigInt?
  academic_year          academic_year            @relation(fields: [academic_year_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  application            application?             @relation(fields: [application_id], references: [id], onUpdate: NoAction)
  school_class           school_class             @relation(fields: [class_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  lead                   lead?                    @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  school                 school                   @relation(fields: [school_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  section                section                  @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student                student                  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  application_progress   application_progress?
  documents              documents[]
  student_fee_assignment student_fee_assignment[]

  @@index([academic_year_id], map: "idx_admission_academic_year_id")
  @@index([application_id], map: "idx_admission_application_id")
  @@index([class_id], map: "idx_admission_class_id")
  @@index([lead_id], map: "idx_admission_lead_id")
  @@index([school_id], map: "idx_admission_school_id")
  @@index([section_id], map: "idx_admission_section_id")
  @@index([status], map: "idx_admission_status")
  @@index([student_id], map: "idx_admission_student_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
